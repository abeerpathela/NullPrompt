{
  "manifest_version": 3,
  "name": "NullPrompt",
  "version": "1.1",
  "description": "Unified Zero-Trust AI Privacy Shield",
  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content/nullprompt-core.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}